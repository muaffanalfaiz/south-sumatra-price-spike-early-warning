.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Data files (too large for git - document download sources in README)
*.csv
*.xlsx
*.parquet
data/raw/
data/processed/

